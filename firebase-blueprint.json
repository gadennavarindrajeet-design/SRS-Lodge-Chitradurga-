{
  "entities": {
    "lodge": {
      "title": "Lodge",
      "description": "Represents a lodge, PG, or hostel in the system.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the lodge" },
        "ownerName": { "type": "string", "description": "Name of the owner" },
        "ownerPhone": { "type": "string", "description": "Phone number of the owner" },
        "email": { "type": "string", "description": "Email of the lodge" },
        "address": { "type": "string", "description": "Physical address of the lodge" },
        "subscriptionStatus": { "type": "string", "enum": ["trial", "monthly", "yearly", "expired"], "description": "Current subscription status" },
        "trialStartDate": { "type": "string", "format": "date-time", "description": "When the trial started" },
        "subscriptionExpiry": { "type": "string", "format": "date-time", "description": "When the subscription expires" },
        "is_super_admin": { "type": "boolean", "description": "Whether this lodge is the super admin account" },
        "is_disabled": { "type": "boolean", "description": "Whether the lodge account is suspended" },
        "totalRevenue": { "type": "number", "description": "Total revenue generated by the lodge" },
        "blacklistedGuests": { "type": "array", "items": { "type": "string" }, "description": "List of encrypted Aadhaar numbers of blacklisted guests" }
      },
      "required": ["name", "ownerName", "email", "subscriptionStatus"]
    },
    "room": {
      "title": "Room",
      "description": "Represents a room within a lodge.",
      "type": "object",
      "properties": {
        "lodgeID": { "type": "string", "description": "Reference to the lodge" },
        "room_number": { "type": "string", "description": "Room number" },
        "type": { "type": "string", "description": "Room type (e.g., Single, Double, AC)" },
        "price": { "type": "number", "description": "Price per night" },
        "status": { "type": "string", "enum": ["available", "occupied", "cleaning"], "description": "Current status of the room" },
        "customer_name": { "type": "string", "description": "Name of the current guest" },
        "customer_id": { "type": "string", "description": "ID of the current guest" },
        "customer_phone": { "type": "string", "description": "Phone of the current guest" },
        "check_in_date": { "type": "string", "format": "date-time", "description": "When the current guest checked in" },
        "advance_paid": { "type": "number", "description": "Advance paid by the current guest" }
      },
      "required": ["lodgeID", "room_number", "type", "price", "status"]
    },
    "customer": {
      "title": "Customer",
      "description": "Represents a guest who has stayed at a lodge.",
      "type": "object",
      "properties": {
        "lodgeID": { "type": "string", "description": "Reference to the lodge" },
        "name": { "type": "string", "description": "Guest name" },
        "phone": { "type": "string", "description": "Guest phone number" },
        "aadhaar": { "type": "string", "description": "Encrypted Aadhaar number" },
        "aadhaarDisplay": { "type": "string", "description": "Masked Aadhaar for display (e.g., **** **** 1234)" },
        "address": { "type": "string", "description": "Guest address" },
        "room": { "type": "string", "description": "Room number stayed in" },
        "checkIn": { "type": "string", "format": "date-time", "description": "Check-in date and time" },
        "checkOut": { "type": "string", "format": "date-time", "description": "Check-out date and time" },
        "numPersons": { "type": "number", "description": "Number of persons staying" },
        "purposeOfVisit": { "type": "string", "description": "Purpose of visit" },
        "amount": { "type": "number", "description": "Total amount paid" },
        "aadhaarImageURL": { "type": "string", "description": "URL to the Aadhaar card image in storage" },
        "invoiceURL": { "type": "string", "description": "URL to the generated PDF invoice" }
      },
      "required": ["lodgeID", "name", "phone", "aadhaar", "checkIn"]
    },
    "staff": {
      "title": "Staff",
      "description": "Represents a staff member of a lodge.",
      "type": "object",
      "properties": {
        "lodgeID": { "type": "string", "description": "Reference to the lodge" },
        "name": { "type": "string", "description": "Staff name" },
        "email": { "type": "string", "description": "Staff email" },
        "role": { "type": "string", "enum": ["Manager", "ReceptionStaff", "CleaningStaff"], "description": "Staff role" }
      },
      "required": ["lodgeID", "name", "email", "role"]
    },
    "subscription": {
      "title": "Subscription",
      "description": "Represents a subscription payment record.",
      "type": "object",
      "properties": {
        "lodgeID": { "type": "string", "description": "Reference to the lodge" },
        "planType": { "type": "string", "enum": ["monthly", "yearly"], "description": "Plan type" },
        "paymentID": { "type": "string", "description": "Razorpay payment ID" },
        "amount": { "type": "number", "description": "Amount paid" },
        "startDate": { "type": "string", "format": "date-time", "description": "Subscription start date" },
        "expiryDate": { "type": "string", "format": "date-time", "description": "Subscription expiry date" },
        "status": { "type": "string", "description": "Payment status" }
      },
      "required": ["lodgeID", "planType", "paymentID", "amount", "startDate", "expiryDate"]
    },
    "whatsapp_log": {
      "title": "WhatsApp Log",
      "description": "Logs of WhatsApp messages sent.",
      "type": "object",
      "properties": {
        "lodgeID": { "type": "string", "description": "Reference to the lodge" },
        "to": { "type": "string", "description": "Recipient phone number" },
        "message": { "type": "string", "description": "Message content" },
        "status": { "type": "string", "description": "Delivery status" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" }
      },
      "required": ["lodgeID", "to", "message", "status", "timestamp"]
    }
  },
  "firestore": {
    "/lodges/{lodgeID}": { "schema": "lodge", "description": "Lodge profiles" },
    "/rooms/{roomID}": { "schema": "room", "description": "Room inventory" },
    "/customers/{customerID}": { "schema": "customer", "description": "Guest records" },
    "/staff/{staffID}": { "schema": "staff", "description": "Staff accounts" },
    "/subscriptions/{subID}": { "schema": "subscription", "description": "Payment history" },
    "/whatsapp_logs/{logID}": { "schema": "whatsapp_log", "description": "WhatsApp communication logs" }
  }
}
